# 北斗 (Beidou) 环境变量配置
# 复制为 .env 并修改

# 应用
APP_NAME=北斗
APP_VERSION=1.0.0
DEBUG=false

# 安全密钥（务必修改！）
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-another-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 默认管理员（首次启动自动创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@beidou.local

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/novelwriter.db

# CORS（前端域名，逗号分隔）
CORS_ORIGINS=["*"]

# 前端 API 地址（Zeabur 部署时设置为后端域名）
# VITE_API_BASE=https://your-backend.zeabur.app/api
