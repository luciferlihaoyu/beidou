# 北斗 (Beidou) — Environment Configuration
# Copy to .env and adjust values for your deployment

# Application
APP_NAME=北斗 (Beidou)
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string

# JWT
JWT_SECRET_KEY=change-me-to-another-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@novelwriter.local

# OpenClaw AI
OPENCLAW_WS_URL=ws://openclaw:4000/ws

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/novelwriter.db
