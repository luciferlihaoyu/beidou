# 北斗 (Beidou) Backend — Environment Configuration
# Copy to .env and fill in your values

# Application
APP_NAME=北斗 (Beidou)
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=sqlite+aiosqlite:///./novelwriter.db

# JWT
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default Admin (created on first boot)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@novelwriter.local

# AI / OpenClaw WebSocket
OPENCLAW_WS_URL=ws://localhost:4000/ws

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]
